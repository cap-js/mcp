{
  "name": "@cap-js/mcp",
  "version": "1.1.1",
  "description": "CAP plugin to expose services as MCP servers for AI agent consumption",
  "repository": "cap-js/mcp",
  "files": [
    "lib",
    "cds-plugin.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1"
  },
  "peerDependencies": {
    "@sap/cds": ">=8",
    "express": ">=4"
  },
  "scripts": {
    "watch:sample": "cds w tests/bookshop",
    "watch:sample:hybrid": "cds bind --exec -- cds w tests/bookshop",
    "inspect": "npx @modelcontextprotocol/inspector --transport \"http\" --server-url \"http://localhost:4004/mcp/catalog\"",
    "test": "node --experimental-vm-modules npx jest",
    "test:hybrid": "cds bind --exec -- npm run test",
    "test:reporting": "node --experimental-vm-modules npx jest --silent --ci --collectCoverage --reporters=default --coverageReporters=text --coverageReporters=cobertura",
    "compile:sample": "cd tests/bookshop && cds compile srv/cat-service.cds -2 mcp",
    "lint": "npx eslint .",
    "prettier": "npx -y prettier@3 --write .",
    "prettier:check": "npx -y prettier@3 --check ."
  },
  "keywords": [
    "cap",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent"
  ],
  "author": "SAP SE (https://www.sap.com)",
  "license": "SEE LICENSE IN LICENSE",
  "cds": {
    "protocols": {
      "mcp": {
        "path": "/mcp",
        "impl": "@cap-js/mcp/lib",
        "clients": {}
      }
    },
    "cdsc": {
      "docs": true
    },
    "mcp": {
      "autowire": true
    }
  },
  "workspaces": [
    "tests/*"
  ]
}
