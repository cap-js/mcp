{
  "name": "@cap-js/mcp",
  "version": "0.0.4",
  "description": "CAP plugin to expose services as MCP servers for AI agent consumption",
  "files": [
    "lib",
    "cds-plugin.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.6",
    "@toon-format/toon": "^2.1.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^13.0.0",
    "test-exclude": "^8.0.0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "*",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0"
  },
  "peerDependencies": {
    "@sap/cds": "^9",
    "express": "^4 || ^5.0.0"
  },
  "scripts": {
    "watch:sample": "cds w tests/bookshop",
    "watch:sample:hybrid": "cds bind --exec -- cds w tests/bookshop",
    "inspect": "npx @modelcontextprotocol/inspector --transport \"http\" --server-url \"http://localhost:4004/mcp/catalog\"",
    "generate-sample-card": "cd tests/bookshop && cds c srv -s CatalogService -2 mcp > expected-catalog-service-card.json",
    "test": "npm run generate-sample-card && node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:hybrid": "cds bind --exec -- npm run test",
    "test:reporting": "npx jest --silent --ci --collectCoverage --reporters=default --reporters=jest-junit --coverageReporters=text --coverageReporters=cobertura",
    "compile:sample": "cd tests/bookshop && cds compile srv/cat-service.cds -2 mcp"
  },
  "keywords": [
    "cap",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent"
  ],
  "author": "SAP SE (https://www.sap.com)",
  "license": "SEE LICENSE IN LICENSE",
  "cds": {
    "log": {
      "levels": {
        "sql": "info",
        "cds": "info"
      }
    }
  },
  "workspaces": [
    "tests/*",
    "ord/"
  ]
}
