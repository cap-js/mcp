{
  "name": "@cap-js/mcp",
  "version": "1.0.0",
  "description": "CAP plugin to expose services as MCP servers for AI agent consumption",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "*",
    "@toon-format/toon": "^2.1.0",
    "jest": "^30.0.0"
  },
  "peerDependencies": {
    "@sap/cds": "^9",
    "express": "^4 || ^5.0.0"
  },
  "scripts": {
    "test": "npx jest --silent",
    "test:hybrid": "cds bind --exec -- npm run test",
    "inspect": "npx @modelcontextprotocol/inspector",
    "watch:sample": "cds w tests/bookshop",
    "watch:sample:hybrid": "cds bind --exec -- cds w tests/bookshop"
  },
  "keywords": [
    "cap",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "ISC",
  "cds": {
    "log": {
      "levels": {
        "sql": "info",
        "cds": "info"
      }
    }
  },
  "workspaces": [
    "tests/*"
  ]
}
