{
  "name": "bookshop",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^3",
    "@cap-js/mcp": "file:../../",
    "@sap/xssec": "^4",
    "@toon-format/toon": "^2.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "better-sqlite3": "12.10.0"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "log": {
      "levels": {
        "sql": "info",
        "cds": "info"
      }
    },
    "mcp": {
      "per_action_tool": false,
      "toon_format": true,
      "prefix": false
    },
    "hana": {
      "fuzzy": false
    },
    "requires": {
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "application-logging": true
    }
  }
}
