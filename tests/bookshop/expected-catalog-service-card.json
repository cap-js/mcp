{
  "$schema": "https://pages.github.tools.sap/CPA/mcp-protocol/spec-v1/mcp-server-card-spec.schema.json",
  "name": "sap.cds.services/catalog",
  "title": "CatalogService",
  "version": "1.0.0",
  "supportedProtocolVersions": [
    "2025-11-25"
  ],
  "description": "Catalog service for browsing books.\nProvides read access to the book catalog including genres and au",
  "instructions": "Use the 'describe' tool to explore the data model and available actions/functions. Then use 'query' to read data or 'call_action' to invoke actions or functions.",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://todo.com/mcp/catalog"
    }
  ],
  "capabilities": {
    "tools": {}
  },
  "tools": [
    {
      "name": "query",
      "description": "Query any entity in CatalogService service. Use describe to discover available entities and their fields.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "entity": {
            "type": "string",
            "enum": [
              "Books",
              "Genres",
              "Currencies"
            ],
            "description": "The entity to query"
          },
          "where": {
            "description": "CQN where clause as array of tokens. Format: [expr, operator, expr, keyword?, expr, operator, expr, ...]\n\nExpressions:\n- Field reference: { \"ref\": [\"fieldName\"] }\n- Literal value: { \"val\": value }\n- List of values: { \"list\": [{ \"val\": v1 }, { \"val\": v2 }] }\n- Nested expression: { \"xpr\": [...tokens...] }",
            "type": "array",
            "items": {
              "$ref": "#/tools/0/inputSchema/definitions/__schema0"
            }
          },
          "select": {
            "description": "List of fields or aggregate expressions to return.\nDefaults to all fields if not specified.\n- Field name: \"fieldName\" or \"association.field\" for path expressions\n- Ref path: { \"ref\": [\"assoc\", \"field\"], \"as\": \"alias\" } for explicit path with optional alias\n- Expand: { \"ref\": [\"assoc\"], \"expand\": [{ \"ref\": [\"field1\"] }, { \"ref\": [\"field2\"] }] } for to-many associations as nested arrays. Use [\"*\"] to expand all fields.\n- Aggregate: { \"func\": \"count|sum|avg|min|max\", \"args\": [\"*\"] or [{ \"ref\": [\"field\"] }], \"as\": \"alias\" }\n\nExamples:\n- [\"title\", \"price\"] - select fields\n- [{ \"ref\": [\"author\", \"name\"], \"as\": \"authorName\" }] - select association field with alias\n- [{ \"ref\": [\"books\"], \"expand\": [{ \"ref\": [\"title\"] }, { \"ref\": [\"price\"] }] }] - expand to-many as nested array\n- [{ \"func\": \"count\", \"args\": [\"*\"], \"as\": \"total\" }] - count all rows\n- [\"author_ID\", { \"func\": \"sum\", \"args\": [{ \"ref\": [\"stock\"] }], \"as\": \"totalStock\" }] - group field + aggregate",
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "ref": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "as": {
                      "type": "string"
                    },
                    "expand": {
                      "type": "array",
                      "items": {
                        "$ref": "#/tools/0/inputSchema/definitions/__schema2"
                      }
                    }
                  },
                  "required": [
                    "ref"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "func": {
                      "type": "string",
                      "enum": [
                        "count",
                        "sum",
                        "avg",
                        "min",
                        "max"
                      ],
                      "description": "Aggregate function name"
                    },
                    "args": {
                      "type": "array",
                      "items": {
                        "anyOf": [
                          {
                            "type": "string",
                            "const": "*"
                          },
                          {
                            "type": "object",
                            "properties": {
                              "ref": {
                                "minItems": 1,
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              }
                            },
                            "required": [
                              "ref"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      },
                      "description": "Function arguments: [\"*\"] for count(*), or [{ ref: [\"field\"] }] for field aggregates"
                    },
                    "as": {
                      "description": "Result column alias",
                      "type": "string"
                    }
                  },
                  "required": [
                    "func",
                    "args"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          },
          "groupBy": {
            "description": "Field(s) to group results by for aggregation queries. Use with aggregate functions in select.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limit": {
            "description": "Maximum number of results to return (default: 20)",
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "orderBy": {
            "description": "Array of order expressions to sort results.\n\nEach expression:\n- ref: Field reference as array, e.g. [\"fieldName\"] or [\"assoc\", \"field\"]\n- sort: \"asc\" or \"desc\" (optional)\n- nulls: \"first\" or \"last\" (optional)\n\nExamples:\n- [{ \"ref\": [\"price\"], \"sort\": \"desc\" }] - sort by price descending\n- [{ \"ref\": [\"name\"] }, { \"ref\": [\"date\"], \"sort\": \"desc\" }] - multi-field sort",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ref": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "sort": {
                  "type": "string",
                  "enum": [
                    "asc",
                    "desc"
                  ]
                },
                "nulls": {
                  "type": "string",
                  "enum": [
                    "first",
                    "last"
                  ]
                }
              },
              "required": [
                "ref"
              ],
              "additionalProperties": false
            }
          },
          "distinct": {
            "description": "Return only unique/distinct rows",
            "type": "boolean"
          },
          "one": {
            "description": "Return a single record object instead of an array. Implies limit of 1.",
            "type": "boolean"
          }
        },
        "required": [
          "entity"
        ],
        "additionalProperties": false,
        "definitions": {
          "__schema0": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "ref": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "ref"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "val": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "boolean"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "val"
                ],
                "additionalProperties": false
              },
              {
                "$ref": "#/tools/0/inputSchema/definitions/__schema1"
              },
              {
                "type": "object",
                "properties": {
                  "xpr": {
                    "type": "array",
                    "items": {
                      "$ref": "#/tools/0/inputSchema/definitions/__schema0"
                    }
                  }
                },
                "required": [
                  "xpr"
                ],
                "additionalProperties": false
              },
              {
                "type": "string",
                "enum": [
                  "=",
                  "==",
                  "!=",
                  "<",
                  "<=",
                  ">",
                  ">="
                ]
              },
              {
                "type": "string",
                "enum": [
                  "in",
                  "like",
                  "and",
                  "or",
                  "not",
                  "between"
                ]
              }
            ]
          },
          "__schema1": {
            "type": "object",
            "properties": {
              "list": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "ref": {
                          "minItems": 1,
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      },
                      "required": [
                        "ref"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "val": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "number"
                            },
                            {
                              "type": "boolean"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        }
                      },
                      "required": [
                        "val"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "$ref": "#/tools/0/inputSchema/definitions/__schema1"
                    }
                  ]
                }
              }
            },
            "required": [
              "list"
            ],
            "additionalProperties": false
          },
          "__schema2": {
            "anyOf": [
              {
                "type": "string",
                "const": "*"
              },
              {
                "type": "object",
                "properties": {
                  "ref": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "as": {
                    "type": "string"
                  },
                  "expand": {
                    "type": "array",
                    "items": {
                      "$ref": "#/tools/0/inputSchema/definitions/__schema2"
                    }
                  }
                },
                "required": [
                  "ref"
                ],
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "describe",
      "description": "Describe the data model of CatalogService service. Returns an overview of all entities and actions with descriptions. Specify 'entity' to get element details, or 'action' to get parameter details.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "entity": {
            "description": "Specific entities to get element details for.",
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Books",
                "Genres",
                "Currencies"
              ]
            }
          },
          "action": {
            "description": "Specific actions or functions to get parameter details for.",
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sum",
                "stock",
                "add",
                "submitOrder"
              ]
            }
          }
        },
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "call_action",
      "description": "Call an unbound action or function in CatalogService service. Use describe to discover available actions and their parameters.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "sum",
              "stock",
              "add",
              "submitOrder"
            ],
            "description": "The action or function to call"
          },
          "parameters": {
            "description": "Parameters for the action. Use describe to see available parameters.",
            "type": "object",
            "properties": {},
            "additionalProperties": {}
          }
        },
        "required": [
          "action"
        ],
        "additionalProperties": false
      },
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      }
    }
  ]
}
